# ═══════════════════════════════════════════════════════════════
# FAMILY TREE APPLICATION - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values below
# 3. NEVER commit .env to git (it's in .gitignore)
# 4. Change ALL passwords to strong, unique values
# ═══════════════════════════════════════════════════════════════

# ─── Database Configuration ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
DB_NAME=family_tree

# ─── Server Configuration ──────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Admin Authentication ──────────────────────────────────────
# CRITICAL: Change this to a strong password before deployment!
# Minimum 12 characters, mix of letters, numbers, symbols
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD_NOW

# ─── Security Settings ─────────────────────────────────────────
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Session secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=GENERATE_RANDOM_SECRET_HERE

# ─── Optional: Cloud/Hosting Configuration ────────────────────
# For Railway/Render/Heroku - they auto-set DATABASE_URL
# DATABASE_URL=mysql://user:password@host:port/dbname

# ─── File Upload Configuration ─────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=./uploads
