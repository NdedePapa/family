# ═══════════════════════════════════════════════════════════════
# FAMILY TREE - GIT IGNORE CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# ─── Environment & Secrets ─────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Dependencies ──────────────────────────────────────────────
node_modules/

# ─── System Files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
*.pid
*.seed
*.pid.lock

# ─── Uploads & Media ───────────────────────────────────────────
uploads/photos/*
!uploads/photos/.gitkeep

# ─── Database Backups ──────────────────────────────────────────
backups/*.sql
*.sqlite
*.db

# ─── Temporary Files ───────────────────────────────────────────
temp/
tmp/
*.tmp
*.bak
*.swp
*~

# ─── IDE & Editor Files ────────────────────────────────────────
.vscode/
.idea/
*.sublime-*
.history/

# ─── Build & Distribution ──────────────────────────────────────
dist/
build/
.cache/
